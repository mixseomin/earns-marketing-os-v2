# MOS v2 environment template
# Copy to .env.local (dev) or .env.production (prod), fill values.

# Postgres — separate DB from v1 ("mos2_dev" / "mos2_prod")
DATABASE_URL=postgresql://mos2:CHANGE_ME@127.0.0.1:5432/mos2_dev

# Tenant id — single-tenant default
DEFAULT_TENANT_ID=self

# Web port — v2 runs on 3812 (v1 = 3811)
WEB_PORT=3812
NEXT_PUBLIC_BASE_URL=https://mos2.on.tc

# Optional integrations (fill when ready)
# DIRECTUS_URL=
# DIRECTUS_TOKEN=
