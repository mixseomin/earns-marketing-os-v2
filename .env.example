# MOS v2 environment template
# Copy to .env.local (dev) or .env.production (prod), fill values.

# Postgres — separate DB from v1 ("mos2_dev" / "mos2_prod")
DATABASE_URL=postgresql://mos2:CHANGE_ME@127.0.0.1:5432/mos2_dev

# Tenant id — single-tenant default
DEFAULT_TENANT_ID=self

# Web port — v2 runs on 3821 (v1 takes 3811 + 3812 for zero-downtime pair)
WEB_PORT=3821
NEXT_PUBLIC_BASE_URL=https://mos2.on.tc

# Bridge to as.on.tc Directus — READ-ONLY (per decision 2026-04-28 v5).
# Used by /p/[id]/resources Accounts vault to import existing accounts,
# and by `npm run sync-from-directus` to pull campaigns/contacts/knowledge.
DIRECTUS_URL=https://as.on.tc
DIRECTUS_TOKEN=

# OpenAI — used for AI Suggestions, Content Studio co-pilot, Auto-lessons.
# Default model gpt-4o-mini for low cost; switch to gpt-4o for higher quality.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
