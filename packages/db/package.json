{
  "name": "@mos2/db",
  "version": "0.0.1",
  "description": "MOS v2 — Drizzle schema + migrations + seed",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts"
  },
  "scripts": {
    "generate": "drizzle-kit generate",
    "migrate": "tsx src/migrate.ts",
    "seed": "tsx src/seed.ts",
    "mark-fixed": "tsx src/mark-fixed.ts",
    "roadmap-status": "tsx src/roadmap-status.ts",
    "sync-from-directus": "tsx src/sync-from-directus.ts",
    "studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.0",
    "postgres": "^3.4.4",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.19.2",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
